{
  "name": "deptex-backend",
  "version": "0.1.0",
  "description": "Deptex backend API - Core logic for dependency tracking and security",
  "main": "dist/index.js",
  "scripts": {
    "dev": "cross-env NODE_PATH=node_modules tsx watch src/index.ts",
    "dev:ce": "cross-env DEPTEX_EDITION=ce tsx watch src/index.ts",
    "build": "tsc",
    "start": "cross-env NODE_PATH=node_modules tsx src/index.ts",
    "test": "cross-env NODE_PATH=node_modules DEPTEX_EDITION=ee jest",
    "type-check": "tsc --noEmit",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:baseline": "tsx scripts/migrate.ts baseline",
    "migrate:status": "tsx scripts/migrate.ts status",
    "e2e:fleet:live": "tsx scripts/e2e-fleet-live.ts",
    "e2e:fleet:drain": "tsx scripts/e2e-fleet-drain.ts",
    "fleet:probe": "tsx scripts/fleet-probe.ts",
    "tracker:probe": "tsx scripts/tracker-probe.ts",
    "reconcile:billing": "tsx scripts/reconcile-billing.ts",
    "loadtest:deduct": "tsx scripts/loadtest-deduct-balance.ts",
    "e2e:billing-prepaid": "tsx scripts/e2e-billing-prepaid.ts",
    "e2e:sentry": "tsx scripts/e2e-sentry.ts",
    "backfill:advisory-details": "tsx scripts/backfill-advisory-details.ts",
    "aegis:iterate": "cross-env NODE_PATH=node_modules tsx scripts/aegis-iterate/cli.ts",
    "aegis:gate-test": "cross-env NODE_PATH=node_modules tsx scripts/aegis-iterate/language-gate-test.ts"
  },
  "keywords": [
    "dependency-tracking",
    "security",
    "sbom"
  ],
  "author": "",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.50",
    "@ai-sdk/google": "^3.0.34",
    "@ai-sdk/openai": "^3.0.37",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@anthropic-ai/sdk": "^0.39.0",
    "@apidevtools/swagger-parser": "^12.1.0",
    "@google/generative-ai": "^0.24.0",
    "@node-saml/node-saml": "^5.1.0",
    "@react-pdf/renderer": "^4.3.2",
    "@sentry/node": "^10.55.0",
    "@supabase/supabase-js": "^2.39.0",
    "@upstash/qstash": "^2.9.0",
    "@upstash/redis": "^1.25.0",
    "ai": "^6.0.106",
    "bullmq": "^5.34.0",
    "cors": "^2.8.5",
    "deptex-depscanner": "file:../depscanner",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.4.1",
    "ipaddr.js": "^2.3.0",
    "isolated-vm": "^5.0.4",
    "jsonwebtoken": "^9.0.2",
    "node-stream-zip": "^1.15.0",
    "nodemailer": "^7.0.11",
    "openai": "^4.20.0",
    "pacote": "^21.3.1",
    "resend": "^6.12.4",
    "safe-regex2": "^5.1.1",
    "semver": "^7.7.4",
    "simple-git": "^3.32.3",
    "stripe": "^20.4.0",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^7.0.4",
    "@types/pacote": "^11.1.8",
    "@types/semver": "^7.7.1",
    "@types/supertest": "^6.0.3",
    "cross-env": "^7.0.3",
    "esbuild": "^0.24.2",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "zod": "$zod"
  }
}
