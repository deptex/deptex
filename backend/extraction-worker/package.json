{
  "name": "deptex-extraction-worker",
  "version": "0.1.0",
  "description": "Extraction worker for Deptex - Clone, cdxgen SBOM, dep-scan, Semgrep, TruffleHog",
  "main": "dist/index.js",
  "bin": {
    "deptex-scan": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "schema:dump": "tsx scripts/dump-schema.ts",
    "smoke:pglite": "tsx test/smoke-pglite.ts",
    "test:storage": "tsx test/storage-pglite.test.ts",
    "cli": "tsx src/cli/index.ts",
    "test:fixtures": "tsx test/snapshot.ts"
  },
  "keywords": ["extraction", "sbom", "dep-scan"],
  "license": "LicenseRef-FSL-1.1-ALv2",
  "dependencies": {
    "@cyclonedx/cdxgen": "^11.0.0",
    "@electric-sql/pglite": "^0.2.0",
    "@supabase/supabase-js": "^2.39.0",
    "@upstash/redis": "^1.25.0",
    "dotenv": "^16.3.1",
    "oxc-parser": "^0.15.0",
    "simple-git": "^3.22.0",
    "stream-json": "^1.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
