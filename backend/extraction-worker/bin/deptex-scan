#!/usr/bin/env bash
#
# deptex-scan — Docker-based wrapper for the local extraction CLI.
#
# Usage:
#   ./bin/deptex-scan run <path> [options]
#   ./bin/deptex-scan --help
#
# The wrapper mounts the workspace + output directory into the container and
# invokes `node /app/dist/cli/index.js` inside the bundled image. All heavy
# tools (cdxgen, dep-scan, semgrep, trufflehog, atom, Python/Go/Java runtimes)
# ship in the image — the host only needs Docker.
#
# Override the image with DEPTEX_CLI_IMAGE=<ref>.

set -euo pipefail

# Prevent MSYS/Git Bash on Windows from rewriting Linux paths we pass into the
# container (e.g. `/app/dist/cli/index.js` → `C:/Program Files/Git/app/...`).
export MSYS_NO_PATHCONV=1
export MSYS2_ARG_CONV_EXCL='*'

IMAGE="${DEPTEX_CLI_IMAGE:-deptex-cli:local}"

if ! docker info >/dev/null 2>&1; then
  echo "error: Docker daemon is not running. Start Docker Desktop and retry." >&2
  exit 2
fi

if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
  echo "error: image '$IMAGE' not found. Build it first:" >&2
  echo "  npm run docker:build" >&2
  echo "or set DEPTEX_CLI_IMAGE=<ref> to point at a remote tag." >&2
  exit 2
fi

# Anything other than the `run <path>` subcommand (help, bad args, etc.) is
# passed through verbatim — the CLI prints its own help/error.
if [ "${1:-}" != "run" ]; then
  exec docker run --rm -i "$IMAGE" node /app/dist/cli/index.js "$@"
fi

shift  # consume `run`

if [ $# -lt 1 ]; then
  echo "error: missing <path> after 'run'" >&2
  echo "usage: deptex-scan run <path> [options]" >&2
  exit 2
fi

WORKSPACE_PATH="$1"
shift

if [ ! -d "$WORKSPACE_PATH" ]; then
  echo "error: workspace path '$WORKSPACE_PATH' is not a directory" >&2
  exit 2
fi

ABS_WS="$(cd "$WORKSPACE_PATH" && pwd)"

# Extract --output so we can mount the directory; everything else passes through.
# Also default --label to the host workspace basename (inside the container the
# workspace is always mounted at /workspace, so without this the label would be
# "workspace" for every project).
#
# Both the equals form (--output=./path) and the space form (--output ./path)
# are accepted — Node's parseArgs accepts either, so dropping the space form
# silently routed writes to an ephemeral path inside the container (the bare
# `--output` token fell through to PASSTHROUGH, the wrapper injected its own
# `--output=/output`, and Node's last-wins parse sent findings to the user's
# unmounted path, which disappeared on container exit).
OUTPUT_DIR="./extraction-results"
HAS_LABEL=0
PASSTHROUGH=()
args=("$@")
i=0
while [ $i -lt ${#args[@]} ]; do
  arg="${args[$i]}"
  case "$arg" in
    --output=*) OUTPUT_DIR="${arg#--output=}" ;;
    --output)
      i=$((i + 1))
      if [ $i -ge ${#args[@]} ]; then
        echo "error: --output requires a value" >&2
        exit 2
      fi
      OUTPUT_DIR="${args[$i]}"
      ;;
    --label=*) HAS_LABEL=1; PASSTHROUGH+=("$arg") ;;
    --label)
      i=$((i + 1))
      if [ $i -ge ${#args[@]} ]; then
        echo "error: --label requires a value" >&2
        exit 2
      fi
      HAS_LABEL=1
      PASSTHROUGH+=("--label=${args[$i]}")
      ;;
    *) PASSTHROUGH+=("$arg") ;;
  esac
  i=$((i + 1))
done

if [ "$HAS_LABEL" = "0" ]; then
  PASSTHROUGH+=("--label=$(basename "$ABS_WS")")
fi

mkdir -p "$OUTPUT_DIR"
ABS_OUT="$(cd "$OUTPUT_DIR" && pwd)"

TTY_FLAG=()
if [ -t 1 ]; then
  TTY_FLAG=(-t)
fi

# On Linux, Docker volume mounts preserve host UIDs, so files written by the
# containerized `worker` user (UID 1000) become owned by UID 1000 on the host
# — wrong for anyone whose host UID isn't 1000. Pass --user to run as the
# invoking user instead. Docker Desktop (macOS/Windows) remaps automatically,
# so this guard is Linux-only.
USER_FLAG=()
if [ "$(uname)" = "Linux" ]; then
  USER_FLAG=(--user "$(id -u):$(id -g)")
fi

# Forward AI-provider env vars when set on the host. ANTHROPIC_API_KEY
# triggers EPD's local-CLI escape (epd.ts) so the AI verification path
# runs without seeding an encrypted BYOK row in the local PGLite DB.
# ANTHROPIC_MODEL is optional — pin a cheaper model (e.g. Haiku) for
# testing. Both vars are read from the host shell; nothing is persisted.
#
# DEPTEX_LOCAL_CLI=1 is set by this wrapper unconditionally so epd.ts
# can distinguish a local CLI invocation from a cloud worker that
# happens to have ANTHROPIC_API_KEY in its env. Without that gate, a
# customer org's failed BYOK decryption could silently fall back to
# the cloud operator's key.
#
# For ANTHROPIC_API_KEY we use the `-e VAR` (no =value) form so the
# secret is forwarded from this script's env into docker without
# landing on docker's argv (which is visible via `ps -ef` and any
# host-level process audit).
ENV_FLAGS=(-e "DEPTEX_LOCAL_CLI=1")
if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
  export ANTHROPIC_API_KEY
  ENV_FLAGS+=(-e ANTHROPIC_API_KEY)
fi
if [ -n "${ANTHROPIC_MODEL:-}" ]; then
  ENV_FLAGS+=(-e "ANTHROPIC_MODEL=$ANTHROPIC_MODEL")
fi
if [ -n "${EPD_MAX_RUN_COST_USD:-}" ]; then
  ENV_FLAGS+=(-e "EPD_MAX_RUN_COST_USD=$EPD_MAX_RUN_COST_USD")
fi
if [ -n "${EPD_BUDGET_EXCEEDED_BEHAVIOR:-}" ]; then
  ENV_FLAGS+=(-e "EPD_BUDGET_EXCEEDED_BEHAVIOR=$EPD_BUDGET_EXCEEDED_BEHAVIOR")
fi
if [ -n "${EPD_MAX_VULNS_PER_RUN:-}" ]; then
  ENV_FLAGS+=(-e "EPD_MAX_VULNS_PER_RUN=$EPD_MAX_VULNS_PER_RUN")
fi

# Phase 5 — per-org AI rule generation. The seed helper inserts an
# organization_reachability_settings row only when DEPTEX_RULE_GENERATION_ENABLED=1
# is set; the rule_generation pipeline step then picks up the BYOK key from
# ANTHROPIC_API_KEY (forwarded above) via the same DEPTEX_LOCAL_CLI escape EPD
# uses. DEPTEX_RULE_PROVIDER / DEPTEX_RULE_MODEL / DEPTEX_RULE_BUDGET_USD are
# optional knobs for cheaper test runs (e.g. claude-haiku-4-5-20251001).
if [ -n "${DEPTEX_RULE_GENERATION_ENABLED:-}" ]; then
  ENV_FLAGS+=(-e "DEPTEX_RULE_GENERATION_ENABLED=$DEPTEX_RULE_GENERATION_ENABLED")
fi
if [ -n "${DEPTEX_RULE_PROVIDER:-}" ]; then
  ENV_FLAGS+=(-e "DEPTEX_RULE_PROVIDER=$DEPTEX_RULE_PROVIDER")
fi
if [ -n "${DEPTEX_RULE_MODEL:-}" ]; then
  ENV_FLAGS+=(-e "DEPTEX_RULE_MODEL=$DEPTEX_RULE_MODEL")
fi
if [ -n "${DEPTEX_RULE_BUDGET_USD:-}" ]; then
  ENV_FLAGS+=(-e "DEPTEX_RULE_BUDGET_USD=$DEPTEX_RULE_BUDGET_USD")
fi
if [ -n "${DEPTEX_RULE_GENERATION_PLATFORM_RULES_DIR:-}" ]; then
  ENV_FLAGS+=(-e "DEPTEX_RULE_GENERATION_PLATFORM_RULES_DIR=$DEPTEX_RULE_GENERATION_PLATFORM_RULES_DIR")
fi

# OpenAI-compatible third-party hosts (DeepInfra, OpenRouter, Alibaba). When
# DEPTEX_RULE_BASE_URL is set, the rule_generation step routes the openai-
# style call to that host instead of api.openai.com. Forward the matching
# host-specific API key by name; the in-container resolver picks the right
# one based on which host the base URL points at. Like ANTHROPIC_API_KEY
# above we use `-e VAR` (no =value) so secrets stay off docker's argv.
if [ -n "${DEPTEX_RULE_BASE_URL:-}" ]; then
  ENV_FLAGS+=(-e "DEPTEX_RULE_BASE_URL=$DEPTEX_RULE_BASE_URL")
fi
if [ -n "${DEEPINFRA_API_KEY:-}" ]; then
  export DEEPINFRA_API_KEY
  ENV_FLAGS+=(-e DEEPINFRA_API_KEY)
fi
if [ -n "${OPENROUTER_API_KEY:-}" ]; then
  export OPENROUTER_API_KEY
  ENV_FLAGS+=(-e OPENROUTER_API_KEY)
fi
if [ -n "${DASHSCOPE_API_KEY:-}" ]; then
  export DASHSCOPE_API_KEY
  ENV_FLAGS+=(-e DASHSCOPE_API_KEY)
fi
if [ -n "${OPENAI_API_KEY:-}" ]; then
  export OPENAI_API_KEY
  ENV_FLAGS+=(-e OPENAI_API_KEY)
fi
if [ -n "${GOOGLE_API_KEY:-}" ]; then
  export GOOGLE_API_KEY
  ENV_FLAGS+=(-e GOOGLE_API_KEY)
fi
if [ -n "${GOOGLE_AI_API_KEY:-}" ]; then
  export GOOGLE_AI_API_KEY
  ENV_FLAGS+=(-e GOOGLE_AI_API_KEY)
fi

# Forward a GitHub token (PAT or App installation) so patch-fetch hits the
# 5000/hr authenticated rate limit instead of 60/hr anonymous. Without this,
# busy local CLI sessions burn through the anon quota and every CVE fails
# with `patch_fetch: GitHub commit metadata returned 403`. Like
# ANTHROPIC_API_KEY above we use `-e VAR` (no =value) to keep the secret off
# docker's argv. GITHUB_TOKEN is the canonical name; GITHUB_PAT is accepted
# as a fallback so a single env file works for both backend and CLI use.
if [ -n "${GITHUB_TOKEN:-}" ]; then
  export GITHUB_TOKEN
  ENV_FLAGS+=(-e GITHUB_TOKEN)
fi
if [ -n "${GITHUB_PAT:-}" ]; then
  export GITHUB_PAT
  ENV_FLAGS+=(-e GITHUB_PAT)
fi

exec docker run --rm -i "${TTY_FLAG[@]}" "${USER_FLAG[@]}" "${ENV_FLAGS[@]}" \
  -v "$ABS_WS:/workspace" \
  -v "$ABS_OUT:/output" \
  "$IMAGE" \
  node /app/dist/cli/index.js run /workspace --output=/output "${PASSTHROUGH[@]}"
