# =============================================================================
# Deptex backend configuration
#
# Copy this file to `.env` (same directory — the backend loads from project
# root, workers from `backend/.env` via dotenv — symlink or copy as needed).
#
# Vars are grouped:
#   (a) REQUIRED for any deploy (self-host or cloud)
#   (b) REQUIRED FOR CLOUD-DEPLOY only (Fly / Stripe / Upstash / QStash)
#   (c) OPTIONAL
#
# Frontend (Vite) env vars live in frontend/.env.example.
# =============================================================================


# -----------------------------------------------------------------------------
# (a) REQUIRED for any deploy
# -----------------------------------------------------------------------------

# Supabase (hosted or local `supabase start`). If local, URL is http://127.0.0.1:54321.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 32-byte hex (run `openssl rand -hex 32`). AES-256-GCM key for the
# organization_registry_credentials table (IaC v2 registry auth). BYOK AI
# was retired in phase29_drop_byok; the same encryption helper is reused
# here so the env var stays.
AI_ENCRYPTION_KEY=

# Shared secret between backend API and internal/worker endpoints.
INTERNAL_API_KEY=

# Shared secret the depscanner (formerly extraction-worker) presents to the backend.
EXTRACTION_WORKER_SECRET=

# Backend HTTP port / public URLs used by CORS + webhook callbacks.
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# GitHub App (required for repo fetch, webhooks, PR checks).
# Create one at https://github.com/settings/apps/new — see docs/self-hosting.md.
GITHUB_APP_ID=
GITHUB_APP_NAME=
GITHUB_APP_PRIVATE_KEY=
# ...or point to the .pem file on disk instead of inlining:
# GITHUB_APP_PRIVATE_KEY_PATH=/absolute/path/to/private-key.pem
GITHUB_WEBHOOK_SECRET=

# At least one AI provider is required to exercise AI features.
# Tier 1 (platform features — docs assistant, policy AI). Gemini Flash, cheap.
GOOGLE_AI_API_KEY=

# Async job queue backend. Options:
#   qstash  — Upstash QStash (cloud). Set QSTASH_TOKEN + signing keys below.
#   bullmq  — BullMQ + local Redis (self-host). Set REDIS_URL below.
#   noop    — no async jobs (app boots, but enrichment + crons are disabled).
#   (unset) — auto: qstash if QSTASH_TOKEN is set, else bullmq if REDIS_URL is
#             set, else noop.
JOB_QUEUE_BACKEND=

# BullMQ: Redis connection string (ignored unless JOB_QUEUE_BACKEND=bullmq).
# For local docker: redis://localhost:6379
REDIS_URL=


# -----------------------------------------------------------------------------
# (b) REQUIRED for CLOUD-DEPLOY only
# Skip these when self-hosting; the app degrades gracefully.
# -----------------------------------------------------------------------------

# Upstash QStash (async jobs, crons). Self-host uses BullMQ + Redis instead — see
# docs/self-hosting.md. Leaving these unset disables cloud-backed queues.
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
QSTASH_REGION=

# Upstash Redis (cache + rate limits). For self-host, point these at any Redis
# that speaks the REST API (Upstash-compatible) or run `docker run redis`.
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Fly.io worker management (depscanner + fix-worker on scale-to-zero).
# FLY_DEPSCANNER_APP is the new canonical var; FLY_EXTRACTION_APP is read as
# a fallback during the rename rollover (Phase 23).
FLY_API_TOKEN=
FLY_DEPSCANNER_APP=
FLY_EXTRACTION_APP=
FLY_FIX_APP=
# FLY_MACHINE_ID is injected by Fly at runtime — do not set locally.

# DeepInfra (optional). Hosts open-weight models (Qwen, DeepSeek, Llama)
# at low per-token pricing. OpenAI-API-compatible. Set this to expose
# DeepInfra as a 4th tile in the AI provider picker.
DEEPINFRA_API_KEY=

# Aegis Fix Agent — comma-separated language gate. Default = js,ts,python,go.
# Set to e.g. "js,ts,python,go,java" to enable stretch languages whose
# bootstrap is wired in fix-worker/src/sandbox.ts. Use "all" to
# enable every supported language.
LANGUAGE_GATE=

# Stripe billing. Self-host has no billing; leave blank.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CLIENT_ID=

# Outbound email (transactional notifications).
EMAIL_FROM=
EMAIL_USER=
EMAIL_PASSWORD=

# reCAPTCHA v3 secret — protects marketing/contact forms. Not needed self-host.
RECAPTCHA_SECRET_KEY=


# -----------------------------------------------------------------------------
# (c) OPTIONAL
# -----------------------------------------------------------------------------

# Integration OAuth (enable only the ones you connect from the UI).
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_URL=                      # only for self-hosted GitLab
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=

# Platform AI keys — Aegis, EPD Anthropic fallback, rule generation, and
# the dev / CI scripts read these directly. After the phase29 BYOK retirement
# this is the only AI-key surface.
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# GitHub PAT for dev scripts that query the public API (e.g. check-ghsa.ts).
GITHUB_TOKEN=

# Encryption-key rotation.
AI_ENCRYPTION_KEY_PREV=
AI_ENCRYPTION_KEY_VERSION=

# Extraction tuning.
DEPENDENCY_REFRESH_CONCURRENCY=
DEPENDENCY_REFRESH_DELAY_MS=
DOWNLOAD_REFRESH_DELAY_MS=
DEPSCAN_CACHE_DIR=
DEPSCAN_VERBOSE_LOG=
KEEP_EXTRACT_WORKSPACE=
VDB_HOME=

# EPD (execution-path-dominance) scoring budget.
EPD_MAX_RUN_COST_USD=
EPD_MAX_VULNS_PER_RUN=
EPD_BUDGET_EXCEEDED_BEHAVIOR=

# Fly burst caps (only if using Fly).
FLY_MAX_BURST_MACHINES=
FLY_AIDER_MAX_BURST=
