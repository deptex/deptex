# Dependencies
node_modules/

# Build outputs
dist/
dist-ssr/
*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment variables (all apps)
.env
.env.local
.env.*.local

# Phase 36 (v1.1) — DAST HAR captures. The Replay tab ingests these in-memory
# via POST /replay/preview; no real HAR ever lives in the repo. All test
# fixtures are synthetic (built in code). The Cloudflare HAR Sanitizer pattern
# of "preview before commit" is what we ship — captures hold session cookies,
# Authorization headers, and TOTP secrets (2023 Okta breach class).
# See docs/runbooks/dast-har-import-dogfood.md for the dev-tenant-only
# dogfood procedure.
**/*.har

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# TypeScript compiled outputs (backend)
*.js.map
*.d.ts.map
backend/src/**/*.js
!backend/src/test/mocks/lib-supabase-mock.js
backend/src/**/*.d.ts
backend/watchtower-worker/src/**/*.js
backend/watchtower-worker/src/**/*.d.ts

# Windows crash dumps
*.stackdump

# Keys / secrets
*.pem

# Misc
temp-open-saas

documents

# Claude workflow scratch — ephemeral, never shipped. /plan-feature writes a plan
# here (used through /implement, then discardable); /criticalreview, /criticalaudit,
# and /evaluate-findings write per-run reports here. The regenerated design/feature
# skills under .claude/skills/ ARE tracked — only these working dirs are ignored.
.claude/plans/
.claude/reviews/
.claude/audits/

# OSS corpus harness output (depscanner/scripts/oss-corpus.ts). Per-run
# artefacts are large (cloned workspaces + raw scan JSON) and re-derivable.
# Summary lives at docs/oss-corpus-<date>.md.
oss-corpus-runs/
