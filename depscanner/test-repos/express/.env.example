# Sample env file. The AWS test key below is INTENTIONALLY a seeded value
# that TruffleHog's `aws-access-key` detector flags as "AWS". Keep it NON-canonical: the AWS docs example key AKIAIOSFODNN7EXAMPLE is on every scanner skip-list and never fires. Do not put real
# secrets in any committed file under depscanner/test-repos/.
PORT=4001
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
