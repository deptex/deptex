# Frontend (Vite) environment.
# Copy to `frontend/.env` — only VITE_* vars are exposed to the browser.

# Required
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend API. Defaults to http://localhost:3001 if unset.
VITE_API_BASE_URL=http://localhost:3001

# Optional — reCAPTCHA v3 site key (marketing/contact forms).
VITE_RECAPTCHA_SITE_KEY=

# Optional — Stripe price IDs surfaced on the billing page. Leave blank for self-host.
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=
VITE_STRIPE_PRO_ANNUAL_PRICE_ID=
VITE_STRIPE_TEAM_MONTHLY_PRICE_ID=
VITE_STRIPE_TEAM_ANNUAL_PRICE_ID=
